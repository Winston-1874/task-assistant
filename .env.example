# OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Modèle principal (classification, routeur, proactif)
LLM_MODEL=google/gemini-2.5-flash

# Modèle vision (si besoin pièces jointes V1.1)
LLM_VISION_MODEL=google/gemini-2.5-flash

# Base URL OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Mot de passe application (mono-utilisateur)
# Générer le hash : python -c "import bcrypt; print(bcrypt.hashpw(b'monmotdepasse', bcrypt.gensalt()).decode())"
APP_PASSWORD_HASH=$2b$12$...

# Base de données
DATABASE_URL=sqlite+aiosqlite:///./data/tasks.db

# Capacité journalière en minutes (7h = 420)
DAILY_CAPACITY_MINUTES=420

# Clé secrète session (générer : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changeme_generate_a_real_secret

# Digest matinal activé
DIGEST_ENABLED=true

# Seuil zombie (jours sans toucher)
ZOMBIE_THRESHOLD_DAYS=21

# Tone coaching : concise | encouraging | off
COACHING_TONE=concise

# Environnement : dev | prod
ENVIRONMENT=dev
